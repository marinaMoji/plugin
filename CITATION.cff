    given-names: Daniel Patrick
    affiliation: >-
      Centre de recherche sur les civilisations de l'Asie orientale (CRCAO),
      CNRS
    orcid: https://orcid.org/0000-0001-9115-3931
  - family-names: Pandolfino
    given-names: Marina
    affiliation: >-
      Centre de recherche sur les civilisations de l'Asie orientale (CRCAO),
      École pratique des hautes études (EPHE)
version: 0.3.9
repository-code: https://github.com/marinaMoji/plugin
url: https://norbert.huma-num.fr/marinamoji
license: GPL-3.0-only
keywords:
  - kaeriten
  - kanbun
  - LibreOffice
  - Microsoft Word
  - ONLYOFFICE
  - digital humanities
  - Japanese studies
