{
  "$schema": "marinaMoji kaeriten mapping (v1)",
  "description": "Canonical Unicode marks from marinaMoji IME; display glyphs and render hints for LibreOffice extension and exporters.",
  "version": 2,
  "rendering": {
    "libreoffice_primary": "anchored_frame",
    "libreoffice_frame": {
      "border": false,
      "anchor": "as_character",
      "content_align": "bottom",
      "vert_orient_position_hmm": 0,
      "font_size_pt": 5,
      "font_size_ratio": 0.42,
      "frame_width_hmm": 180,
      "line_height_twips": 0,
      "stack_direction": "top_to_bottom_first_mark_first"
    },
    "fallback": "subscript",
    "word_primary": "ooxml",
    "word_mac_use_ooxml": true,
    "word_mac_ooxml_fallback_api": true,
    "word_mac_ooxml_probe_with_word": true,
    "word_mac_prefer_inline_textbox": true,
    "word_mac_force_solid_fill": false,
    "word_mac_fill_color": "FFFFFF",
    "word_mac_no_outline": true,
    "word_content_control": {
      "font_size_ratio": "12:5",
      "min_font_size_pt": 6,
      "stack_direction": "top_to_bottom_first_mark_first"
    },
    "word_inline_textbox": {
      "font_size_ratio": "12:5",
      "min_font_size_pt": 6,
      "stack_direction": "top_to_bottom_first_mark_first",
      "content_align": "bottom",
      "content_align_horizontal": "center",
      "margin_pt": 0,
      "margin_top_pt": 0,
      "margin_bottom_pt": 0,
      "margin_left_pt": 0,
      "margin_right_pt": 0,
      "frame_width_hmm": 180,
      "frame_width_reference_pt": 12,
      "box_extra_width_right_pt": 2.5,
      "baseline_shift_pt": -4,
      "inline_effect_extent_pt": 0,
      "word_mac_compound_layout": "stack",
      "compound_line_spacing_pt": 4,
      "compound_box_padding_pt": 0.12
    },
    "onlyoffice_primary": "inline_content_control",
    "onlyoffice_inline": {
      "font_size_ratio": 0.42,
      "min_font_size_pt": 6,
      "stack_direction": "top_to_bottom_first_mark_first",
      "compound_layout": "stack",
      "stack_step_hps": 0
    }
  },
