    "libreoffice_frame": {
      "border": false,
      "anchor": "as_character",
      "content_align": "bottom",
      "offset_mm_bottom": 0.2,
      "stack_direction": "top_to_bottom_first_mark_first"
    },
    "fallback": "subscript"
  },
