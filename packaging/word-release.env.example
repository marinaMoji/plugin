# Copy to word-release.env (gitignored) and set your hosted add-in URL.
# No trailing slash. Word loads taskpane.html from this base over HTTPS.
#
#   cp packaging/word-release.env.example packaging/word-release.env
#
# GitHub Pages (marinaMoji/plugin — see docs/GITHUB_PAGES.md):
MARINAMOJI_PLUGIN_BASE=https://marinaMoji.github.io/plugin/word
#
# Alternative self-hosted example:
# MARINAMOJI_PLUGIN_BASE=https://norbert.huma-num.fr/marinamoji/word
MARINAMOJI_RELEASE_VERSION=0.3.7
